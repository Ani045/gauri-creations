RewriteEngine On

# Force /courses to serve courses.php (not the courses/ directory)
RewriteRule ^courses/?$ courses.php [L]

# Remove .php extension from URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# Redirect .php URLs to clean URLs (301)
RewriteCond %{THE_REQUEST} \s/(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Redirect .html URLs to clean URLs (301)
RewriteCond %{THE_REQUEST} \s/(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Redirect index to root
RewriteRule ^index$ / [R=301,L]

# Redirect old course-details hash URLs to new individual pages
RewriteRule ^course-details$ /courses [R=301,L]
